{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "aipolyintelligence-com-v1",
  "main": "src/worker.ts",
  "compatibility_date": "2026-06-26",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": true,
    "not_found_handling": "404-page"
  },
  "observability": {
    "enabled": true
  }
}
