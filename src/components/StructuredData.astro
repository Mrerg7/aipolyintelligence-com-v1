---
import {
  SITE_URL,
  SITE_NAME,
  HERO_IMAGE_URL,
  ACQUISITION_EMAIL,
} from '../lib/constants';

const description =
  'aipolyintelligence.com — The domain for the next evolution of artificial intelligence. A premium, forward-looking name for polyintelligent systems, advanced AI research, and the future of multi-form intelligence.';

const webPage = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: `${SITE_NAME} — The Future of Polyintelligence — Premium Domain`,
  description,
  url: `${SITE_URL}/`,
  inLanguage: 'en-US',
  primaryImageOfPage: {
    '@type': 'ImageObject',
    url: HERO_IMAGE_URL,
    contentUrl: HERO_IMAGE_URL,
  },
  about: {
    '@type': 'Thing',
    name: 'AI Polyintelligence',
    description:
      'Premium domain name asset for polyintelligent AI systems, advanced AI research, and multi-form intelligence.',
  },
};

const organization = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE_NAME,
  url: `${SITE_URL}/`,
  email: ACQUISITION_EMAIL,
  logo: HERO_IMAGE_URL,
  description,
};

const product = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'aipolyintelligence.com domain name',
  description:
    'Premium domain for AI polyintelligence — the next frontier beyond narrow AI. A rare, high-value asset for visionary AI research and development.',
  category: 'Domain Name',
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    price: '19997',
    priceCurrency: 'USD',
    seller: {
      '@type': 'Organization',
      email: ACQUISITION_EMAIL,
    },
    url: `mailto:${ACQUISITION_EMAIL}`,
    shippingDetails: {
      '@type': 'OfferShippingDetails',
      shippingRate: {
        '@type': 'MonetaryAmount',
        value: '0.00',
        currency: 'USD',
      },
      deliveryTime: {
        '@type': 'ShippingDeliveryTime',
        handlingTime: {
          '@type': 'QuantitativeValue',
          minValue: 0,
          maxValue: 1,
          unitCode: 'd',
        },
        transitTime: {
          '@type': 'QuantitativeValue',
          minValue: 0,
          maxValue: 0,
          unitCode: 'd',
        },
      },
      shippingDestination: {
        '@type': 'DefinedRegion',
        addressCountry: 'US',
      },
    },
    hasMerchantReturnPolicy: {
      '@type': 'MerchantReturnPolicy',
      returnPolicyCategory: 'https://schema.org/MerchantReturnFiniteReturnWindow',
      returnMethod: 'https://schema.org/ReturnByMail',
      returnFees: 'https://schema.org/FreeReturn',
      applicableCountry: 'US',
      merchantReturnDays: {
        '@type': 'QuantitativeValue',
        minValue: 0,
        maxValue: 0,
        unitCode: 'd',
      },
    },
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(webPage)} />
<script type="application/ld+json" set:html={JSON.stringify(organization)} />
<script type="application/ld+json" set:html={JSON.stringify(product)} />
