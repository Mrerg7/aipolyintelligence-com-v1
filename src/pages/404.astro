---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — aipolyintelligence.com"
  description="The page you were looking for could not be found. Explore aipolyintelligence.com — the premium domain for AI polyintelligence."
  noindex={true}
>
  <main class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center max-w-lg">
      <div
        class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-white/5 border border-white/10 mb-8"
      >
        <span class="text-4xl font-display text-white/50">404</span>
      </div>
      <h1 class="text-3xl font-semibold tracking-tight mb-4">Page not found</h1>
      <p class="text-white/60 mb-8">
        The page you were looking for doesn't exist or has been moved. The domain
        aipolyintelligence.com is available for acquisition.
      </p>
      <a
        href="/"
        class="inline-flex items-center justify-center px-8 py-3.5 rounded-2xl bg-white text-[#0a0a0f] font-semibold hover:bg-white/90 transition-all"
      >
        Return Home
      </a>
    </div>
  </main>
</BaseLayout>
